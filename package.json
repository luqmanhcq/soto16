{
  "name": "soto16",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "start:3001": "next start -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",

    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:dev": "pm2 start ecosystem.config.cjs --env development --only soto16-dev",
    "pm2:stop": "pm2 stop soto16",
    "pm2:stop:dev": "pm2 stop soto16-dev",
    "pm2:stop:all": "pm2 stop all",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --only soto16",
    "pm2:restart": "pm2 restart soto16",
    "pm2:delete": "pm2 delete soto16",
    "pm2:delete:all": "pm2 delete all",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs soto16",
    "pm2:logs:dev": "pm2 logs soto16-dev",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",

    "deploy": "npm run build && npm run pm2:reload",
    "deploy:fresh": "npm run build && pm2 start ecosystem.config.cjs",

    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:migrate:prod": "npx tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:seed": "npx tsx lib/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.446.0",
    "next": "16.2.1",
    "postgres": "^3.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.22.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}